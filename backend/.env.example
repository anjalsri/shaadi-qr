# Shaadi QR Backend Environment Configuration

# Django Core Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Defaults to SQLite if not provided)
# DATABASE_URL=postgres://user:password@localhost:5432/shaadi_qr

# CORS Configurations
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Authentication & OTP Mock Settings
# Set MOCK_OTP=True to bypass SMTP email setup during local development. 
# Verification OTPs will be printed in the server logs/console.
MOCK_OTP=True

# Email Settings (for sending verification links / OTPs / forgot password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Payment Integration (Razorpay)
# Razorpay Test Credentials (for local staging and payments verification)
RAZORPAY_KEY_ID=rzp_test_yourKeyId
RAZORPAY_KEY_SECRET=yourRazorpaySecret
# Set to True to allow mock local payments without calling Razorpay API
RAZORPAY_TEST_MODE=True

# Storage Configuration (Local vs Cloudinary)
# If left blank, Django will store uploaded files on the local filesystem.
# Set this to write directly to Cloudinary for production.
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
